# --- App ---
DATABASE_URL=postgresql+psycopg://portfolio:portfolio@db:5432/portfolio
APP_ENV=dev

# --- Метрики: FREE-путь (см. docs/api/README.md) ---
# Скоринг на бесплатных сигналах: Wayback + РКН + Spamhaus + OpenPageRank (DR-прокси).
# Платный провайдер (ahrefs/dataforseo/checktrust) — опциональная стадия позже.
METRICS_PROVIDER=openpagerank     # openpagerank(free) | ahrefs | dataforseo | checktrust | none
AHREFS_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
CHECKTRUST_API_KEY=

# --- SERP: SearXNG (локально, free) — заменяет платный SERP-API ---
SEARXNG_URL=http://192.168.1.77:8080

# --- A-Parser (локально): whois / SERP-фолбэк / keywords ---
APARSER_URL=http://192.168.1.77:9091
APARSER_API_KEY=                  # API-пароль A-Parser
APARSER_PROXY_CHECKER=    # имя Proxy Checker в A-Parser UI (default: Free Proxy 2) — box-specific

# --- backorder.ru (M1 discovery — публичный/без auth; login нужен для ВЫКУПА в M2) ---
BACKORDER_LOGIN=
BACKORDER_PASSWORD=
BACKORDER_ACCOUNT_ID=
BACKORDER_CONTACT_ID=

# --- optimizator.ru (регистрация освободившихся, M2) ---
OPTIMIZATOR_API_KEY=
OPTIMIZATOR_NICD=

# --- РКН источник (M1 hard-reject) ---
RKN_SOURCE_URL=https://antizapret.prostovpn.org/domains-export.txt   # primary (z-i заморожен 2025-10)

# --- Spamhaus / SURBL (M1 hard-flag) — нужен СВОЙ резолвер (публичные 8.8.8.8/1.1.1.1 блокируются) ---
DNS_RESOLVER=172.28.0.53          # unbound из docker-compose.yml (сеть combine); пусто = системный
SPAMHAUS_DQS_KEY=                 # опц. free DQS-ключ (≤100k/день) как альтернатива своему резолверу

# --- Registrar NS (.ru: reg.ru/nic.ru) — смена NS на Cloudflare в M3 ---
REGRU_USERNAME=
REGRU_PASSWORD=

# --- Cloudflare (M3) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- aaPanel (M3 провижн) ---
AAPANEL_URL=https://YOUR_HOST:8888
AAPANEL_API_KEY=
# PEM-серт панели (self-signed): без него не-loopback URL отвергается (анти-MITM)
AAPANEL_CA_BUNDLE=
VPS_ORIGIN_IP=

# --- LLM: LiteLLM (локально, OpenAI-совм., без ключа) ---
LLM_BASE_URL=http://192.168.1.77:4000
LLM_API_KEY=
LLM_MODEL=mistral                 # mistral(=mistral-large, платно у них) | mistral-small | ollama/<model>

# --- GSC: ИСКЛЮЧЁН из v1 (мониторинг индекса — ручной site: через SearXNG; позже Bing WMT) ---
# GSC_SERVICE_ACCOUNT_JSON=

# --- Локальные опц. сервисы (тот же бокс 192.168.1.77) ---
# BROWSERLESS_URL=http://192.168.1.77:3000   # headless Chrome (JS-рендер; в рантайме избегаем)
# N8N_URL=http://192.168.1.77:5678           # оркестрация воркфлоу (опция)

# --- Self-update (кнопка «Обновить из git» в панели) ---
GITHUB_REPO=kozhan-aff/combine_machine
GITHUB_TOKEN=                                # fine-grained PAT, Contents=Read-only

# --- Panel auth (Basic-auth на всю панель/API) ---
# Панель на LAN без иной защиты (docker-compose). Задай оба, чтобы /admin/pull и
# пайплайн не были доступны любому в сети. Пусто = auth ВЫКЛ (только localhost-dev).
PANEL_USER=
PANEL_PASS=
